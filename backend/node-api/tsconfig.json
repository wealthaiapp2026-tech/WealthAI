{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node",
    "allowJs": true,
    
    /* 🚀 THIS RESOLVES COLLISIONS & SEPARATES FILES CLEANLY */
    "moduleDetection": "force",
    
    /* 🚀 MAXIMUM RELAXED RULES FOR DESTRUCTURING & ELEMENT LOOKUPS */
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,
    
    "esModuleInterop": true,
    "skipLibCheck": true,
    
    /* Ensure code writes to /dist even if type quirks exist */
    "noEmitOnError": false, 
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
 "include": ["src/**/*"],
  "files": ["global.d.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
